-- | Daml script testing delivery versus burn for Amulet.
module Splice.Scripts.TokenStandard.TestAmuletDeliveryVersusBurn where

import Daml.Script

import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationV2 qualified as V2

import Splice.TokenStandard.Utils qualified as TSU

import Splice.Testing.Utils
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as V2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2

import Splice.Scripts.TokenStandard.TestAmuletTokenStandardTestEnv (TestEnv(..), setupTest)


checkTotalSupply : Party -> Decimal -> Script ()
checkTotalSupply dso expected = do
  holdings <- WalletClientV2.listVisibleHoldings dso
  let totalSupply = sum (map (._2.amount) holdings)
  assertMsg ("Expected total supply to be " <> show expected <> " but was " <> show totalSupply) $
    totalSupply == expected

-- | Example usage: paying for the extension of ANS entries.
test_delivery_versus_burn : Script ()
test_delivery_versus_burn = do
  TestEnv{..} <- setupTest
  let dso = instrId.admin
  checkTotalSupply dso 1000.0

  let burnLeg = legV2 with
        receiver = TSU.burnAccount
        amount = 10.0
  let burnSettlement = settlementV2 with
        executors = [dso]

  -- in prod, we'd construct the choice context explicitly, but here it's easier to grab the factory choice context
  enrichedChoice <- V2.getSettlementFactory registryV2 V2.SettlementFactory_SettleBatch with
    actors = [dso]
    settlement = burnSettlement
    transferLegs = []
    allocations = []
    extraArgs = emptyExtraArgs
  let burnExtraArgs = enrichedChoice.arg.extraArgs

  -- test burn via pre-allocated transfer leg using a V1 allocation
  WalletClientV2.allocateV1 registries V1.AllocationSpecification with
    settlement = allocationV1.settlement with executor = dso; meta = emptyMetadata
    transferLegId = "leg1"
    transferLeg = TSU.downcast_v2_v1_TransferLeg instrId.admin burnLeg
  [(allocCid, _)] <- queryInterface @V2.Allocation dso

  WalletClientV2.extractAndCheckTxHistory [dso] $
    submitResultAndTree dso $ exerciseCmd allocCid V2.Allocation_Settle with
      actors = [dso]
      extraTransferLegSides = []
      nextIterationFunding = None
      extraArgs = burnExtraArgs

  checkTotalSupply dso 990.0

  -- test burn via pre-allocated transfer leg
  WalletClientV2.allocateV2 registries alice
    burnSettlement
    allocationV2 with
      transferLegSides = [TSU.senderSide burnLeg]
      nextIterationFunding = None
  [(allocCid, _)] <- queryInterface @V2.Allocation dso

  WalletClientV2.extractAndCheckTxHistory [dso] $
    submitResultAndTree dso $ exerciseCmd allocCid V2.Allocation_Settle with
      actors = [dso]
      extraTransferLegSides = []
      nextIterationFunding = None
      extraArgs = burnExtraArgs

  checkTotalSupply dso 980.0

  -- test burn via iterated allocation
  WalletClientV2.allocateV2 registries alice
    burnSettlement
    allocationV2 with -- allocationV2 has 10 Amulet prefunded
      committed = True

  [(allocCid, _)] <- queryInterface @V2.Allocation dso
  WalletClientV2.extractAndCheckTxHistory [dso] $
    submitResultAndTree dso $ exerciseCmd allocCid V2.Allocation_Settle with
      actors = [dso]
      extraTransferLegSides = [TSU.senderSide burnLeg with amount = 5.0]
      nextIterationFunding = Some $ TextMap.fromList [(instrId.id, 5.0)]
      extraArgs = burnExtraArgs
  checkTotalSupply dso 975.0

  WalletClientV2.checkUnlockedBalance alice instrId 970.0

  pure ()

