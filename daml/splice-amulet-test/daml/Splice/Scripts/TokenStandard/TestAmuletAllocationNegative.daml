test_allocationv2_Withdraw_committed_expired_but_deadlineNotReached : Script ()
test_allocationv2_Withdraw_committed_expired_but_deadlineNotReached = do
  (TestEnv{..}) <- setupTest
  WalletClientV2.allocateV2 registries alice settlementV2 allocationV2 with
    committed = True
    settlementDeadline = Some $ now `addRelTime` days 365

  [(aliceAllocCid, allocView)] <- WalletClientV2.listAllocationsV2 aliceAccount alice
  let Some expiresAt = allocView.expiresAt
  setTime (expiresAt `addRelTime` days 1)

  submitMustFail''
    ( expectMessageContains "Cannot withdraw a committed allocation before its settlement deadline"
    )
    (actAs alice) $ exerciseCmd aliceAllocCid V2.Allocation_Withdraw with
      extraArgs = emptyExtraArgs
      actors = [alice]


