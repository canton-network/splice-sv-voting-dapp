-- | Negative tests checking that the required checks for amulet are enforced for both
-- V1 and V2 amulet allocations.
module Splice.Scripts.TokenStandard.TestAmuletAllocationNegative where

import DA.Foldable (foldMap)
import DA.Time
import DA.Map qualified as Map
import DA.TextMap qualified as TextMap

import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV1 qualified as V1
import Splice.Api.Token.AllocationInstructionV2 qualified as V2

import Splice.TokenStandard.Utils qualified as TSU

import Splice.Testing.Utils
import Splice.Testing.Registries.AmuletRegistryV2 qualified as AmuletRegistryV2
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry
import Splice.Testing.TokenStandard.RegistryApi qualified as V1
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as V2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2

import Splice.Scripts.TokenStandard.TestAmuletTokenStandardTestEnv (TestEnv(..), setupTest, createLockedHoldings)


-- Testing V1.AllocationFactory_Allocate
----------------------------------------

test_allocateV1_generic : (TestEnv -> Script (V1.AllocationFactory_Allocate, FailureStatusCheck)) -> Script ()
test_allocateV1_generic mkTestCase = do
  env@(TestEnv{..}) <- setupTest
  (choiceArg, check) <- mkTestCase env
  registryV1 <- MultiRegistry.getRegistryApiV1 env.registries instrId.admin
  enrichedChoice <- V1.getAllocationFactory registryV1 choiceArg
  submitMustFail'' check
    -- We grant readAs instr.admin to be able to test using holdings from the wrong account
    (actAs alice <> discloseMany' enrichedChoice.disclosures <> readAs instrId.admin) $
      exerciseCmd enrichedChoice.factoryCid enrichedChoice.arg

test_allocateV1_requestedAt : Script ()
test_allocateV1_requestedAt = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now `addRelTime` microseconds 1
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectErrorId "stdlib.daml.com/deadline-not-exceeded")

test_allocateV1_allocateBefore : Script ()
test_allocateV1_allocateBefore = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1 with
          settlement = allocationV1.settlement with
            allocateBefore = now `addRelTime` microseconds (-1)
            settleBefore = now -- it must be in the future
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectErrorId "stdlib.daml.com/deadline-exceeded")

test_allocateV1_settleBefore : Script ()
test_allocateV1_settleBefore = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1 with
          settlement = allocationV1.settlement with
            allocateBefore = now `addRelTime` microseconds (2) -- cannot be later than settleBefore
            settleBefore = now `addRelTime` microseconds (1)
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectMessageContains "'allocation.settlement.allocateBefore' is greater than 'allocation.settlement.settleBefore'") --

test_allocateV1_authorizer_nonBasicAccount : Script ()
test_allocateV1_authorizer_nonBasicAccount = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let nonBasicAccount = V2.Account with
        owner = Some alice
        provider = None
        id = "extraAccount"
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1 with
          transferLeg = allocationV1.transferLeg with
            meta = TSU.accountToMeta "sender" nonBasicAccount emptyMetadata
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectMessageContains "Expected a basic account for field 'allocation.authorizer', but got: Account {owner = Some 'alice', provider = None, id = \"extraAccount\"}")

test_allocateV1_cannotUseLockedHoldings : Script ()
test_allocateV1_cannotUseLockedHoldings = test_allocateV1_generic $ \env@(TestEnv {..}) -> do
  inputHoldingCids <- createLockedHoldings env alice 100.0 (now `addRelTime` days 365)
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure $ (,) choiceArg $
    -- The code attempts to unlock in all cases, but fails because the deadline is not yet exceeded
    expectErrorId "stdlib.daml.com/deadline-not-exceeded" <>
    expectMessageContains "Ledger time is strictly before deadline 'Lock.expiresAt' at 2023-01-01T00:00:00Z"

test_allocateV1_noHoldings : Script ()
test_allocateV1_noHoldings = test_allocateV1_generic $ \TestEnv {..} -> do
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1
        inputHoldingCids = []
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure $ (,) choiceArg $
    expectUnmetRequirement "At least one input holding must be provided for allocations that require funding"

test_allocateV1_insufficientFunds : Script ()
test_allocateV1_insufficientFunds = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1 with
          transferLeg = allocationV1.transferLeg with
            amount = 10000.0
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure $ (,) choiceArg $
    expectErrorId "splice.lfdecentralizedtrust.org/insufficient-funds" <>
    expectMessageContains "Insufficient funds: you are missing 9000.0 to complete this transfer."

test_allocateV1_inputHoldingCids_wrongAdmin : Script ()
test_allocateV1_inputHoldingCids_wrongAdmin = test_allocateV1_generic $ \TestEnv {..} -> do
  anotherAmuletV2 <- AmuletRegistryV2.initialize AmuletRegistryV2.defaultAmuletRegistryConfig
  AmuletRegistryV2.tapFaucet anotherAmuletV2 alice 500.0
  inputHoldingCids <- WalletClientV2.listHoldingCids alice anotherAmuletV2.instrumentId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectMessageContains "Contract group identifier mismatch") -- Due to using fetchAndArchive with `ForOwner`

test_allocateV1_inputHoldingCids_wrongOwner : Script ()
test_allocateV1_inputHoldingCids_wrongOwner = test_allocateV1_generic $ \TestEnv {..} -> do
  AmuletRegistryV2.tapFaucet registriesEnv.amuletV2 bob 500.0
  inputHoldingCids <- WalletClientV2.listHoldingCids bob instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectMessageContains "Contract group identifier mismatch") -- Due to using fetchAndArchive with `ForOwner`

test_allocateV1_allocation_wrongAdmin : Script ()
test_allocateV1_allocation_wrongAdmin = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = bob
        allocation = allocationV1
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectMessageContains  "The requirement 'Expected admin 'bob' matches actual admin")

test_allocateV1_transferLeg_wrongInstrumentId : Script ()
test_allocateV1_transferLeg_wrongInstrumentId = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1 with
          transferLeg = allocationV1.transferLeg with
            instrumentId = allocationV1.transferLeg.instrumentId with
              id = "WRONG_INSTRUMENT_ID"
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure $ (choiceArg,) $
    expectMessageContains "'transferLeg.instrumentId' is not equal to 'expected value'" <>
    expectMessageContains "WRONG_INSTRUMENT_ID"

test_allocateV1_transferLeg_negativeAmount : Script ()
test_allocateV1_transferLeg_negativeAmount = test_allocateV1_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V1.AllocationFactory_Allocate with
        expectedAdmin = instrId.admin
        allocation = allocationV1 with
          transferLeg = allocationV1.transferLeg with
            amount = -10.0
        inputHoldingCids = map TSU.downcast inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
  pure $ (choiceArg,) $
    expectMessageContains "'transferLeg.amount' is not greater than 'zero'"


-- Testing V2.AllocationFactory_Allocate
----------------------------------------

test_allocateV2_cannotUseLockedHoldings : Script ()
test_allocateV2_cannotUseLockedHoldings = do
  env@(TestEnv {..}) <- setupTest
  inputHoldingCids <- createLockedHoldings env alice 100.0 (now `addRelTime` days 365)
  registryV2 <- MultiRegistry.getRegistryApiV2 registries instrId.admin
  enrichedChoice <- V2.getAllocationFactory registryV2 V2.AllocationFactory_Allocate with
    settlement = settlementV2
    allocation = allocationV2
    inputHoldingCids
    requestedAt = now
    actors = [alice]
    extraArgs = emptyExtraArgs
  -- The code attempts to unlock in all cases, but fails because the deadline is not yet exceeded
  submitMustFail''
   ( expectErrorId "stdlib.daml.com/deadline-not-exceeded" <>
     expectMessageContains "Ledger time is strictly before deadline 'Lock.expiresAt' at 2023-01-01T00:00:00Z"
   )
   (actAs alice <> discloseMany' enrichedChoice.disclosures) $
    exerciseCmd enrichedChoice.factoryCid enrichedChoice.arg

test_allocateV2_requestedAt : Script ()
test_allocateV2_requestedAt = test_allocateV2_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V2.AllocationFactory_Allocate with
        settlement = settlementV2
        allocation = allocationV2
        inputHoldingCids
        requestedAt = now `addRelTime` microseconds 1
        extraArgs = emptyExtraArgs
        actors = [alice]
  pure (choiceArg, expectErrorId "stdlib.daml.com/deadline-not-exceeded")

test_allocateV2_settlementDeadline : Script ()
test_allocateV2_settlementDeadline = test_allocateV2_generic $ \TestEnv {..} -> do
