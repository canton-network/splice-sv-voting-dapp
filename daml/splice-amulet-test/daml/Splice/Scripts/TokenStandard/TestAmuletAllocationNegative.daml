  pure (choiceArg, expectMessageContains "'allocation.admin' is not equal to 'expected value'")

test_allocateV2_transferLegSides_wrongInstrumentId : Script ()
test_allocateV2_transferLegSides_wrongInstrumentId = test_allocateV2_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let choiceArg = V2.AllocationFactory_Allocate with
        settlement = settlementV2
        allocation = allocationV2 with
          transferLegSides =
            [ V2.TransferLegSide with
                transferLegId = "leg1"
                instrumentId = "WRONG_INSTRUMENT_ID"
                side = V2.SenderSide
                otherside = TSU.basicAccount bob
                amount = 10.0
                meta = emptyMetadata
            ]
        inputHoldingCids
        requestedAt = now
        extraArgs = emptyExtraArgs
        actors = [alice]
  pure $ (choiceArg,) $
    expectMessageContains "'transferLeg.instrumentId' is not equal to 'expected value'" <>
    expectMessageContains "WRONG_INSTRUMENT_ID"

test_allocateV2_transferLegSides_nonBasicAccount : Script ()
test_allocateV2_transferLegSides_nonBasicAccount = test_allocateV2_generic $ \TestEnv {..} -> do
  inputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let nonBasicAccount = V2.Account with
        owner = Some alice
        provider = None
        id = "extraAccount"
  let choiceArg = V2.AllocationFactory_Allocate with
        settlement = settlementV2
        allocation = allocationV2 with
          transferLegSides = [ TSU.senderSide legV2 with receiver = nonBasicAccount ]
        inputHoldingCids
        requestedAt = now
        actors = [alice]
        extraArgs = emptyExtraArgs
  pure (choiceArg, expectMessageContains "Expected a basic account for field 'transferLeg.otherside', but got: Account {owner = Some 'alice', provider = None, id = \"extraAccount\"}")

test_allocateV2_wrongActor : Script ()
test_allocateV2_wrongActor = test_allocateV2_generic $ \TestEnv {..} -> do
  let choiceArg = V2.AllocationFactory_Allocate with
        settlement = settlementV2
        allocation = allocationV2 with
          authorizer = TSU.basicAccount bob
        inputHoldingCids = []
        requestedAt = now
        extraArgs = emptyExtraArgs
        actors = [alice]
  pure (choiceArg, expectMessageContains "'actors' does not have the same elements as one of 'allowed actors'")

test_allocateV2_generic : (TestEnv -> Script (V2.AllocationFactory_Allocate, FailureStatusCheck)) -> Script ()
test_allocateV2_generic mkTestCase = do
  env@(TestEnv{..}) <- setupTest
  (choiceArg, check) <- mkTestCase env
  enrichedChoice <- V2.getAllocationFactory registryV2 choiceArg
  submitMustFail'' check
    -- We grant readAs instr.admin to be able to test using holdings from the wrong account
    (actAs alice <> discloseMany' enrichedChoice.disclosures <> readAs instrId.admin) $
      exerciseCmd enrichedChoice.factoryCid enrichedChoice.arg


-- Testing V2.SettlementFactory_SettleBatch
-------------------------------------------

data SettleTestEnv = SettleTestEnv with
  aliceAllocCid : ContractId V2.Allocation
  bobAllocCid : ContractId V2.Allocation
  bobAllocationV2 : V2.AllocationSpecification

test_settleBatchV2_wrongActor : Script ()
test_settleBatchV2_wrongActor = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          , V2.FinalizedAllocation bobAllocCid [] None
          ]
        extraArgs = emptyExtraArgs
        actors = [bob]
  pure $ (,) choiceArg $
    expectMessageContains "'actors' does not have the same elements as one of 'allowed actors'" <>
    expectMessageContains "allowed actors: [['provider1','provider2']]"

test_settleBatchV2_tooFewAllocs : Script ()
test_settleBatchV2_tooFewAllocs = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "'missing authorizations' is not equal to 'empty set'." <>
    expectMessageContains "side = ReceiverSide"

test_settleBatchV2_tooManyAllocs : Script ()
test_settleBatchV2_tooManyAllocs = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = []
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "'superfluous authorizations' is not equal to 'empty set'" <>
    expectMessageContains "side = SenderSide"

test_settleBatchV2_duplicate_transferLegs : Script ()
test_settleBatchV2_duplicate_transferLegs = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2, legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          , V2.FinalizedAllocation bobAllocCid [] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "Expected unique SettleBatch.transferLegsIds, but found duplicates:" <>
    expectMessageContains "leg1"

test_settleBatchV2_duplicateAllocs_same_cid : Script ()
test_settleBatchV2_duplicateAllocs_same_cid = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          , V2.FinalizedAllocation bobAllocCid [] None
          , V2.FinalizedAllocation bobAllocCid [] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "Expected unique transferLegIds of allocated authorizations, but found duplicates" <>
    expectMessageContains "ReceiverSide"

test_settleBatchV2_duplicateAllocs_different_cid : Script ()
test_settleBatchV2_duplicateAllocs_different_cid = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  WalletClientV2.allocateV2 registries bob settlementV2 bobAllocationV2
  bobAllocs <- WalletClientV2.listAllocationsV2 bobAccount bob
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None ] <>
          [ V2.FinalizedAllocation bobAllocCid [] None | (bobAllocCid, _) <- bobAllocs ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "Expected unique transferLegIds of allocated authorizations, but found duplicates" <>
    expectMessageContains "ReceiverSide"

test_settleBatchV2_nonIterated_noExtraLegs : Script ()
test_settleBatchV2_nonIterated_noExtraLegs = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          , V2.FinalizedAllocation bobAllocCid [TSU.receiverSide legV2] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "'finalizedAllocation.extraTransferLegSides' is not equal to 'expected value'" <>
    expectMessageContains "expected value: []"

test_settleBatchV2_nonIterated_noNextIterationFunding : Script ()
test_settleBatchV2_nonIterated_noNextIterationFunding = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          , V2.FinalizedAllocation bobAllocCid [] (Some TextMap.empty)
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "no next iteration funding allowed when iterated settlement is disabled"

test_settleBatchV2_wrongAllocationAdmin: Script ()
test_settleBatchV2_wrongAllocationAdmin = do
  (TestEnv{..}) <- setupTest
  WalletClientV2.allocateV2 registries alice settlementV2 allocationV2
  -- create extra amulet registry and allocate Bob's alloction
  anotherAmuletV2 <- AmuletRegistryV2.initialize AmuletRegistryV2.defaultAmuletRegistryConfig
  let registries' = Map.singleton anotherAmuletV2.dso (MultiRegistry.mkRegistryApisV2 anotherAmuletV2)
  WalletClientV2.allocateV2 registries' bob settlementV2 $
    allocationV2 with
      authorizer = bobAccount
      nextIterationFunding = Some TextMap.empty
      admin = anotherAmuletV2.dso
  [(aliceAllocCid, _)] <- WalletClientV2.listAllocationsV2 aliceAccount alice
  [(bobAllocCid, _)] <- WalletClientV2.listAllocationsV2 bobAccount bob
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] None
          , V2.FinalizedAllocation bobAllocCid [TSU.receiverSide legV2] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  -- need to avoid fetching choice contexts for the actual allocations, as they can't be resolved
  -- by the AmuletRegistryV2 scripts due to the different admin
  enrichedChoice <- V2.getSettlementFactory registryV2 choiceArg with allocations = []
  submitMustFail''
    (expectMessageContains  "'allocation.admin' is not equal to 'expected value'")
    (foldMap actAs choiceArg.actors <> discloseMany' enrichedChoice.disclosures) $
      exerciseCmd enrichedChoice.factoryCid enrichedChoice.arg with allocations = choiceArg.allocations

test_settleBatchV2_nextIterationFunding_wrongInstrumentId: Script ()
test_settleBatchV2_nextIterationFunding_wrongInstrumentId = test_settleBatchV2_generic $ \SettleTestEnv {..} TestEnv {..} -> do
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [legV2]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide legV2] (Some $ TextMap.fromList [("BAD_INSTRUMENT_ID", 10.0)])
          , V2.FinalizedAllocation bobAllocCid [] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  pure $ (,) choiceArg $
    expectMessageContains "'nextIterationFunding.instrumentId' is not equal to 'expected value'" <>
    expectMessageContains "BAD_INSTRUMENT_ID"


-- | Test overflow from the net amount of two legs being larger than the max or min decimal value.
test_settleBatchV2_decimal_overflow : Script ()
test_settleBatchV2_decimal_overflow = do
  (TestEnv{..}) <- setupTest
  let aliceAllocationV2 = allocationV2
  let bobAllocationV2 = aliceAllocationV2 with
        authorizer = TSU.basicAccount bob
        nextIterationFunding = Some mempty
  let maxDecimal = 9999999999999999999999999999.9999999999 : Decimal
  let leg1 = legV2
  let leg2 = legV2 with
        transferLegId = "leg2"
        amount = maxDecimal
  let leg3 = legV2 with
        sender = legV2.receiver
        receiver = legV2.sender
        transferLegId = "leg3"
        amount = maxDecimal
  WalletClientV2.allocateV2 registries alice settlementV2 aliceAllocationV2
  WalletClientV2.allocateV2 registries bob settlementV2 bobAllocationV2
  [(aliceAllocCid, _)] <- WalletClientV2.listAllocationsV2 aliceAccount alice
  [(bobAllocCid, _)] <- WalletClientV2.listAllocationsV2 bobAccount bob
  let choiceArg = V2.SettlementFactory_SettleBatch with
        settlement = settlementV2
        transferLegs = [leg1, leg2, leg3]
        allocations =
          [ V2.FinalizedAllocation aliceAllocCid [TSU.senderSide leg1, TSU.senderSide leg2, TSU.receiverSide leg3] None
          , V2.FinalizedAllocation bobAllocCid [TSU.receiverSide leg1, TSU.receiverSide leg2, TSU.senderSide leg3] None
          ]
        extraArgs = emptyExtraArgs
        actors = [provider1, provider2]
  enrichedChoice <- V2.getSettlementFactory registryV2 choiceArg
  submitMustFail''
    (expectMessageContains  "ArithmeticError while evaluating (ADD_NUMERIC -2.0 -9999999999999999999999999999.9999999999)")
    (foldMap actAs choiceArg.actors <> discloseMany' enrichedChoice.disclosures) $
      exerciseCmd enrichedChoice.factoryCid enrichedChoice.arg

test_settleBatchV2_generic : (SettleTestEnv -> TestEnv -> Script (V2.SettlementFactory_SettleBatch, FailureStatusCheck)) -> Script ()
test_settleBatchV2_generic mkTest = do
  testEnv@(TestEnv{..}) <- setupTest
  WalletClientV2.allocateV2 registries alice settlementV2 allocationV2
  let bobAllocationV2 = allocationV2 with
        authorizer = TSU.basicAccount bob
        transferLegSides = [ TSU.receiverSide legV2 ]
        nextIterationFunding = None
        committed = False
  WalletClientV2.allocateV2 registries bob settlementV2 bobAllocationV2
  [(aliceAllocCid, _)] <- WalletClientV2.listAllocationsV2 aliceAccount alice
  [(bobAllocCid, _)] <- WalletClientV2.listAllocationsV2 bobAccount bob
  (choiceArg, check) <- mkTest (SettleTestEnv {..}) testEnv
  enrichedChoice <- V2.getSettlementFactory registryV2 choiceArg
  submitMustFail'' check
    (foldMap actAs choiceArg.actors <> discloseMany' enrichedChoice.disclosures) $
      exerciseCmd enrichedChoice.factoryCid enrichedChoice.arg


-- Test V2.Allocation_Settle
----------------------------

test_allocation_Settle_generic : (TestEnv -> ExtraArgs -> Script (V2.Allocation_Settle, FailureStatusCheck)) -> Script ()
test_allocation_Settle_generic mkTest = do
  env@(TestEnv{..}) <- setupTest
  enrichedChoice <- V2.getSettlementFactory registryV2 V2.SettlementFactory_SettleBatch with
    settlement = settlementV2
    transferLegs = []
    allocations = []
    extraArgs = emptyExtraArgs
    actors = [provider1, provider2, instrId.admin]
  (choiceArg, check) <- mkTest env enrichedChoice.arg.extraArgs
  [(aliceAllocCid, _)] <- WalletClientV2.listAllocationsV2 aliceAccount alice
  submitMustFail'' check (foldMap actAs choiceArg.actors) $ exerciseCmd aliceAllocCid choiceArg

test_allocationv1_Settle_nonEmpty_extraLegs : Script ()
test_allocationv1_Settle_nonEmpty_extraLegs = test_allocation_Settle_generic $ \TestEnv{..} extraArgs -> do
  WalletClientV2.allocateV1 registries allocationV1
  pure
    ( V2.Allocation_Settle with
        extraTransferLegSides = [TSU.senderSide legV2]
        nextIterationFunding = None
        extraArgs
        actors = [provider1, provider2, instrId.admin]
    , expectMessageContains "'arg.extraTransferLegSides' is not equal to 'expected value'"  <>
      expectMessageContains "expected value: []"
    )

test_allocationv1_Settle_set_nextIterationFunding : Script ()
test_allocationv1_Settle_set_nextIterationFunding = test_allocation_Settle_generic $ \TestEnv{..} extraArgs -> do
  WalletClientV2.allocateV1 registries allocationV1
  pure
    ( V2.Allocation_Settle with
        extraTransferLegSides = []
        nextIterationFunding = Some $ TextMap.fromList [(instrId.id, 0.0)]
        extraArgs
        actors = [provider1, provider2, instrId.admin]
    , expectMessageContains "'arg.nextIterationFunding' is not equal to 'expected value'"  <>
      expectMessageContains "expected value: None"
    )

test_allocationv2_Settle_iterated_extraTransferLeg_nonBasicAccount : Script ()
test_allocationv2_Settle_iterated_extraTransferLeg_nonBasicAccount = test_allocation_Settle_generic $ \TestEnv{..} extraArgs -> do
  let nonBasicAccount = V2.Account with
        owner = Some alice
        provider = None
        id = "extraAccount"
  WalletClientV2.allocateV2 registries alice settlementV2 allocationV2
  pure
    ( V2.Allocation_Settle with
        extraTransferLegSides = [TSU.senderSide legV2 with receiver = nonBasicAccount]
        nextIterationFunding = None
        extraArgs
        actors = [provider1, provider2, instrId.admin]
    , expectMessageContains $ "Expected a basic account for field 'transferLeg.otherside', but got: " <> show nonBasicAccount
    )

test_allocationv1_Settle_wrongActor : Script ()
test_allocationv1_Settle_wrongActor = test_allocation_Settle_generic $ \TestEnv{..} extraArgs -> do
  WalletClientV2.allocateV1 registries allocationV1
  pure
    ( V2.Allocation_Settle with
        extraTransferLegSides = []
        nextIterationFunding = None
        extraArgs
        actors = [alice]
    , expectMessageContains "'actors' does not have the same elements as one of 'allowed actors'" <>
      expectMessageContains ("allowed actors: [[" <> show instrId.admin <> ",'provider1','provider2']]")
    )

test_allocationv2_Settle_wrongActor : Script ()
test_allocationv2_Settle_wrongActor = test_allocation_Settle_generic $ \TestEnv{..} extraArgs -> do
  WalletClientV2.allocateV2 registries alice settlementV2 allocationV2
