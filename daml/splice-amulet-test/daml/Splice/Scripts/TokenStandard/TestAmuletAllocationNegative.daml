test_allocationv1_Settle_after_settlementDeadline : Script ()
test_allocationv1_Settle_after_settlementDeadline = test_allocation_Settle_generic $ \TestEnv{..} extraArgs -> do
  WalletClientV2.allocateV1 registries allocationV1
  setTime allocationV1.settlement.settleBefore
  pure
    ( V2.Allocation_Settle with
        extraTransferLegSides = []
        nextIterationFunding = None
        extraArgs
        actors = [provider1, provider2, instrId.admin]
    , expectErrorId "stdlib.daml.com/deadline-exceeded"
    )

test_allocationv2_Settle_after_settlementDeadline : Script ()
test_allocationv2_Settle_after_settlementDeadline = test_allocation_Settle_generic $ \TestEnv{..} extraArgs -> do
  WalletClientV2.allocateV2 registries alice settlementV2 allocationV2 with
    settlementDeadline = Some $ now `addRelTime` days 1
  passTime (days 1)
  pure
    ( V2.Allocation_Settle with
        extraTransferLegSides = []
        nextIterationFunding = None
        extraArgs
        actors = [provider1, provider2, instrId.admin]
    , expectErrorId "stdlib.daml.com/deadline-exceeded"
    )


