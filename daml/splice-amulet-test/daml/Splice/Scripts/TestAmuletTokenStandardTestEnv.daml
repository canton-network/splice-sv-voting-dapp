-- | Shared test environment setup for amulet allocation tests.
module Splice.Scripts.TestAmuletTokenStandardTestEnv
  (
    TestEnv(..),
    setupTest,
    checkEq,
  ) where

import DA.Action (unless)
import DA.Time
import DA.Text qualified as T
import DA.TextMap qualified as TextMap

import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2

import Splice.TokenStandard.Utils qualified as TSU

import Splice.Testing.Utils
import Splice.Testing.Registries.AmuletRegistryV2 qualified as AmuletRegistryV2
import Splice.Testing.Registries.TestRegistries qualified as TestRegistries
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as V2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2


data TestEnv = TestEnv with
  registriesEnv : TestRegistries.Env
  registries : MultiRegistry.MultiRegistry
  registryV2 : V2.GenericRegistry
  alice : Party
  aliceAccount : V2.Account
  bob : Party
  bobAccount : V2.Account
  provider : Party
  instrId : V2.InstrumentId
  now : Time
  legV2 : V2.TransferLeg
  settlementV2 : V2.SettlementInfo
  allocationV2 : V2.AllocationSpecification
  allocationV1 : V1.AllocationSpecification
  transferV2 : V2.Transfer
  transferArgV2 : V2.TransferFactory_Transfer


setupTest : Script TestEnv
setupTest = do
  env <- TestRegistries.initialize TestRegistries.defaultConfig
  let registries = env.registries
  let instrId = env.amuletV2.instrumentId
  registryV2 <- MultiRegistry.getRegistryApiV2 registries instrId.admin

  alice <- allocatePartyExact "alice"
  bob <- allocatePartyExact "bob"
  provider <- allocatePartyExact "provider"

  let mkAccount = TSU.basicAccount

  -- setup alice
  WalletClientV2.createBatchingUtility alice
  AmuletRegistryV2.tapFaucet env.amuletV2 alice 1000.0

  -- setup bob
  WalletClientV2.createBatchingUtility bob

  now <- getTime
  transferInputHoldingCids <- WalletClientV2.listHoldingCids alice instrId
  let transferV2 = V2.Transfer with
        sender = TSU.basicAccount alice
        receiver = TSU.basicAccount bob
        inputHoldingCids = transferInputHoldingCids
        amount = 10.0
        instrumentId = instrId
        requestedAt = now
        executeBefore = now `addRelTime` days 7
        meta = emptyMetadata

  pure TestEnv with
    registries
    registryV2
    alice
    aliceAccount = mkAccount alice
    bob
    bobAccount = mkAccount bob
    provider
    instrId
    now
    registriesEnv = env

    settlementV2 = V2.SettlementInfo with
      executors = [provider]
      id = "settlement1"
      cid = None
      meta = emptyMetadata
    allocationV2 = V2.AllocationSpecification with
      admin = instrId.admin
      authorizer = mkAccount alice
      transferLegSides = []
      committed = False
      nextIterationFunding = Some $ TextMap.fromList [(instrId.id, 10.0)]
      settlementDeadline = None
      meta = emptyMetadata
    legV2 = V2.TransferLeg with
      transferLegId = "leg1"
      sender = TSU.basicAccount alice
      receiver = TSU.basicAccount bob
      amount = 2.0
      instrumentId = instrId.id
      meta = emptyMetadata

    allocationV1 = V1.AllocationSpecification with
      settlement = V1.SettlementInfo with
        executor = provider
        settlementRef = V1.Reference with
          id = "settlement1"
          cid = None
        requestedAt = now
        allocateBefore = now `addRelTime` days 7
        settleBefore = now `addRelTime` days 365
        meta = emptyMetadata
      transferLegId = "leg1"
      transferLeg = TSU.downcast_v2_v1_TransferLeg instrId.admin $ V2.TransferLeg with
        transferLegId = "leg1"
        sender = mkAccount alice
        receiver = mkAccount bob
        amount = 10.0
        instrumentId = instrId.id
        meta = emptyMetadata

    transferV2
    transferArgV2 = V2.TransferFactory_Transfer with
      transfer = transferV2
      actors = [alice]
      extraArgs = emptyExtraArgs


checkEq : (Eq a, Show a) => Text -> a -> a -> Script ()
checkEq prefix expected actual =
  unless (actual == expected) $
    fail $ T.unlines
      [ prefix <> ": actual values do not match expected values"
      , "  actual: " <> show actual
      , "  expected: " <> show expected
      ]
